# Optional Splunk connection settings for local helper scripts.
# Copy to .env and fill in real values. Never commit .env.

# Splunk management API base URL, usually https://HOSTNAME:8089.
SPLUNK_BASE_URL=https://splunk.example.com:8089

# Use either SPLUNK_TOKEN or SPLUNK_USERNAME/SPLUNK_PASSWORD.
SPLUNK_TOKEN=replace-with-splunk-session-or-bearer-token
SPLUNK_USERNAME=replace-with-username
SPLUNK_PASSWORD=replace-with-password

# Set to false only for labs with self-signed certificates.
SPLUNK_VERIFY_SSL=true

# Optional output location for generated dictionaries.
SPLUNK_DICTIONARY_OUTPUT=./out/splunk-data-dictionary.json
